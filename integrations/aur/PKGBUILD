# Maintainer: Thibaut Melen <contact@supernovae.studio>
# Prebuilt-binary package for the Nika workflow engine (nika.sh).
# Upstream release tarballs contain exactly one file: the static `nika` binary.
pkgname=nika-bin
pkgver=0.105.0
pkgrel=1
pkgdesc="Workflow language + engine for AI pipelines — audit .nika.yaml statically (cost/permits/secrets) before running, verify the hash-chained trace after"
arch=('x86_64' 'aarch64')
url="https://github.com/supernovae-st/nika"
license=('AGPL-3.0-or-later')
provides=('nika')
conflicts=('nika')
source_x86_64=("nika-${pkgver}-x64.tar.gz::${url}/releases/download/v${pkgver}/nika-linux-x64-${pkgver}.tar.gz")
source_aarch64=("nika-${pkgver}-arm64.tar.gz::${url}/releases/download/v${pkgver}/nika-linux-arm64-${pkgver}.tar.gz")
sha256sums_x86_64=('52fb626b58cbed2927de13293a8c68877d2c16f896e023b289760c30c7073f38')
sha256sums_aarch64=('5cc6f7540a3e1ad1bab85a48148d13df5d9a9471221d3c1d331c460832665384')

package() {
  install -Dm755 "${srcdir}/nika" "${pkgdir}/usr/bin/nika"
  # Tarballs ≥0.100 carry completions/ (upstream #487) — install when present,
  # still without ever executing the target-arch binary.
  if [ -d "${srcdir}/completions" ]; then
    install -Dm644 "${srcdir}/completions/nika.bash" "${pkgdir}/usr/share/bash-completion/completions/nika"
    install -Dm644 "${srcdir}/completions/_nika" "${pkgdir}/usr/share/zsh/site-functions/_nika"
    install -Dm644 "${srcdir}/completions/nika.fish" "${pkgdir}/usr/share/fish/vendor_completions.d/nika.fish"
  fi
}
